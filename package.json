{
  "name": "buffer-graphql-pacer",
  "version": "0.0.0",
  "description": "Batching and pacing proxy for Buffer GraphQL API rate limits",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./apollo": {
      "import": {
        "types": "./dist/apollo.d.ts",
        "default": "./dist/apollo.js"
      },
      "require": {
        "types": "./dist/apollo.d.cts",
        "default": "./dist/apollo.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "example:paced": "tsx examples/bulk-schedule-paced.ts",
    "example:live:readonly": "tsx examples/flood-readonly.ts",
    "example:live:ideas": "tsx examples/flood-ideas.ts",
    "example:dashboard": "tsx examples/dashboard-demo.ts"
  },
  "keywords": [
    "buffer",
    "graphql",
    "rate-limit",
    "queue",
    "pacing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chauhannishith/buffer-api-limit.git"
  },
  "peerDependencies": {
    "@apollo/client": "^3.8.0",
    "graphql-request": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "@apollo/client": {
      "optional": true
    },
    "graphql-request": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apollo/client": "3.13.8",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "@types/react": "18.3.20",
    "eslint": "^9.28.0",
    "graphql": "16.11.0",
    "graphql-request": "7.1.2",
    "ink": "5.2.1",
    "msw": "2.10.2",
    "prettier": "^3.5.3",
    "react": "18.3.1",
    "tsup": "^8.5.0",
    "tsx": "4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.1"
  }
}
