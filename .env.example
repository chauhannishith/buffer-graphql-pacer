# Copy to .env for live examples. Loaded by pnpm example:live:* (--env-file=.env).
# Never commit real values.
BUFFER_ACCESS_TOKEN=

# GraphQL endpoint — public API keys use https://api.buffer.com (see Buffer API docs).
BUFFER_GRAPHQL_URL=https://api.buffer.com

# Live examples (examples/flood-*.ts) require explicit opt-in.
RUN_LIVE_TESTS=0

# flood-readonly.ts: paced (default) or unpaced
FLOOD_MODE=paced

# flood-readonly.ts: Ink terminal dashboard (paced only)
DASHBOARD=0
FLOOD_COUNT=110

# flood-ideas.ts: second opt-in for createIdea writes
CONFIRM_IDEAS_FLOOD=0

# bulk-schedule-paced.ts: number of requests in the demo burst
BURST_SIZE=25
